# EJEMPLO de la estructura que genera kubeseal.
# Reemplazar values con los reales corriendo:
#   ./scripts/seal-secrets.sh
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: mobilebank-secrets
  namespace: mobilebank
spec:
  encryptedData:
    API_KEY: AgB7c0F...REEMPLAZAR...==
    JWT_SECRET: AgC8j2P...REEMPLAZAR...==
    DB_PASSWORD: AgDk9L...REEMPLAZAR...==
  template:
    metadata:
      name: mobilebank-secrets
      namespace: mobilebank
    type: Opaque
